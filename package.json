{
  "name": "deskflow",
  "productName": "DeskFlow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "author": "DeskFlow Team",
  "description": "Productivity time tracker for desktop apps and browser",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build": "node scripts/build.mjs",
    "start": "electron .",
    "lint": "eslint .",
    "preview": "vite preview",
    "check:prompt": "node scripts/check-default-prompt.mjs"
  },
  "build": {
    "appId": "com.deskflow.app",
    "productName": "DeskFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.cjs"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/active-win/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "DeskFlow_AppIcon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "DeskFlow_AppIcon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "DeskFlow_AppIcon.png"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@openrouter/sdk": "^0.12.16",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/katex": "^0.16.8",
    "@types/prismjs": "^1.26.6",
    "@types/three": "^0.183.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "active-win": "^8.2.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.9.0",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.35.0",
    "katex": "^0.17.0",
    "lucide-react": "^0.577.0",
    "mailparser": "^3.9.12",
    "mermaid": "^11.16.0",
    "node-imap": "^0.9.6",
    "node-pty": "^1.1.0",
    "postprocessing": "^6.39.0",
    "prismjs": "^1.30.0",
    "r3f-perf": "^7.2.3",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "sql.js": "^1.14.1",
    "sqlite3": "^6.0.1",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "tsdav": "^2.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "asar": "^3.2.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "madge": "^8.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
