        {problem.user_notes && (
          <div className="mb-4">
            <div className="text-xs text-gray-400 mb-1">User Notes</div>
            <div className="text-sm text-gray-300 bg-gray-900 p-2 rounded">{problem.user_notes}</div>
          </div>
        )}

        {/* Related Requests */}
        <div className="mb-4">
          <div className="text-xs text-gray-400 mb-2">Related Requests</div>
          <div className="flex flex-wrap gap-1 mb-2">
            {linkedRequests.length === 0 ? (
              <span className="text-xs text-gray-500">No linked requests</span>
            ) : linkedRequests.map(r => (
              <span key={r.id} className="inline-flex items-center gap-1 px-1.5 py-0.5 bg-green-600/30 text-green-300 text-[10px] rounded">
                #{r.id} {r.title}
                <button
                  onClick={() => handleUnlinkRequest(r.id)}
                  className="text-green-400 hover:text-red-400 ml-0.5"
                  title="Unlink request"
                >
                  ×
                </button>
              </span>
            ))}
          </div>
          <div className="flex gap-2">
            <select
              value={linkRequestId}
              onChange={(e) => setLinkRequestId(e.target.value)}
              className="flex-1 bg-gray-700 border border-gray-600 rounded px-2 py-1 text-xs text-white"
            >
              <option value="">Link a request...</option>
              {allRequests
                .filter(r => !r.linked_problems?.includes(problem.id))
                .map(r => (
                  <option key={r.id} value={r.id}>#{r.id} - {r.title}</option>
                ))}
            </select>
            <button
              onClick={handleLinkRequest}
              disabled={!linkRequestId}
              className="px-2 py-1 bg-green-600 hover:bg-green-700 disabled:bg-gray-700 text-white text-xs rounded"
            >
              Link
            </button>
          </div>
        </div>

        {/* Meta */}
        <div className="text-xs text-gray-500 border-t border-gray-700 pt-3 mt-4">
          <div>Priority: {problem.priority}</div>
          <div>Category: {problem.category}</div>
          <div>Created: {new Date(problem.created_at).toLocaleDateString()}</div>
        </div>
      </div>
    </div>
  );
};

