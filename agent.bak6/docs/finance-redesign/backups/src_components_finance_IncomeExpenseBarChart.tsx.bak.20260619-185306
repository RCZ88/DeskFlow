/**
 * IncomeExpenseBarChart – stacked bar chart of monthly income vs expense.
 * Uses recharts. Values masked when hide‑numbers is active.
 */
import { BarChart, Bar, XAxis, YAxis, Tooltip, ResponsiveContainer, CartesianGrid } from 'recharts';
import { useNumberMask } from '../../context/NumberMaskContext';
import { maskNumber } from '../../utils/maskNumber';
import { fmtCurrency } from '../finance/currency-data';

interface MonthlyData {
  month: string;
  income: number;
  expense: number;
}

interface IncomeExpenseBarChartProps {
  data: MonthlyData[];
  currency: string;
}

export function IncomeExpenseBarChart({ data, currency }: IncomeExpenseBarChartProps) {
  const { showNumbers, maskMode, maskFixedValue } = useNumberMask();

  const formatTick = (val: number) => {
    const formatted = fmtCurrency(val, currency);
    return showNumbers ? formatted : maskNumber(formatted, maskMode, maskFixedValue);
  };

  return (
    <ResponsiveContainer width="100%" height={200}>
      <BarChart data={data}>
        <CartesianGrid strokeDasharray="3 3" stroke="rgba(255,255,255,0.1)" />
        <XAxis dataKey="month" tick={{ fill: '#71717a', fontSize: 10 }} />
        <YAxis tickFormatter={formatTick} tick={{ fill: '#71717a', fontSize: 10 }} />
        <Tooltip
          formatter={(val: number) => (showNumbers ? fmtCurrency(val, currency) : maskNumber(fmtCurrency(val, currency), maskMode, maskFixedValue))}
        />
        <Bar dataKey="income" stackId="a" fill="#22c55e" />
        <Bar dataKey="expense" stackId="a" fill="#ef4444" />
      </BarChart>
    </ResponsiveContainer>
  );
}
